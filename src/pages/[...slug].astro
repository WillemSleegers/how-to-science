---
import { getEntry } from "astro:content"
import Layout from "@/layouts/main.astro"
import { AppShell } from "@/components/AppShell"
import { extractHeadings, stripQuartoToc } from "@/lib/headings"
import { loadNav, collectAllSlugs } from "@/lib/nav"
import type { NavSection } from "@/lib/nav"
import { getGlobalTocDepth } from "@/lib/config"

export async function getStaticPaths() {
  const nav = loadNav()
  const slugs = collectAllSlugs(nav)
  return slugs.map((slug) => ({ params: { slug }, props: { nav } }))
}

const { slug } = Astro.params
const { nav } = Astro.props as { nav: NavSection[] }

const entry = await getEntry("docs", slug)
if (!entry) {
  return new Response(null, { status: 404 })
}

const content = stripQuartoToc(entry.body ?? "")
const headings = extractHeadings(content)
const tocDepth: number = entry.data["toc-depth"] ?? getGlobalTocDepth()
---

<Layout title={entry.data.title ?? slug}>
  <AppShell
    client:load
    content={content}
    title={entry.data.title ?? ""}
    slug={slug}
    headings={headings}
    tocDepth={tocDepth}
    nav={nav}
  />
</Layout>

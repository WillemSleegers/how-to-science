---
import { readFileSync, existsSync } from "node:fs"
import { resolve } from "node:path"
import matter from "gray-matter"
import Layout from "@/layouts/main.astro"
import { AppShell } from "@/components/AppShell"
import { extractHeadings, stripQuartoToc } from "@/lib/headings"
import { loadNav } from "@/lib/nav"
import type { NavSection } from "@/lib/nav"

export async function getStaticPaths() {
  const nav = loadNav()
  return nav.flatMap((group) =>
    group.sections.flatMap((section) =>
      section.pages.map((page) => ({ params: { slug: page.slug }, props: { section } }))
    )
  )
}

const { slug } = Astro.params
const { section } = Astro.props as { section: NavSection }

const mdPath = resolve(process.cwd(), `content/${slug}.md`)
if (!existsSync(mdPath)) {
  return new Response(null, { status: 404 })
}

const raw = readFileSync(mdPath, "utf-8")
const { content: rawContent, data } = matter(raw)
const content = stripQuartoToc(rawContent)
const headings = extractHeadings(content)
---

<Layout title={data.title ?? slug}>
  <AppShell
    client:load
    content={content}
    title={data.title ?? ""}
    slug={slug}
    headings={headings}
    section={section}
  />
</Layout>

---
import { getEntry } from "astro:content"
import Layout from "@/layouts/main.astro"
import { AppShell } from "@/components/AppShell"
import { extractHeadings, stripQuartoToc } from "@/lib/headings"
import { loadNav } from "@/lib/nav"
import type { NavSection } from "@/lib/nav"
import { getGlobalTocDepth } from "@/lib/config"

export async function getStaticPaths() {
  const nav = loadNav()
  return nav.flatMap((group) =>
    group.sections.flatMap((section) => [
      { params: { slug: section.indexSlug }, props: { section } },
      ...section.pages.map((page) => ({ params: { slug: page.slug }, props: { section } })),
    ])
  )
}

const { slug } = Astro.params
const { section } = Astro.props as { section: NavSection }

const entry = await getEntry("docs", slug)
if (!entry) {
  return new Response(null, { status: 404 })
}

const content = stripQuartoToc(entry.body ?? "")
const headings = extractHeadings(content)
const tocDepth: number = entry.data["toc-depth"] ?? getGlobalTocDepth()
---

<Layout title={entry.data.title ?? slug}>
  <AppShell
    client:load
    content={content}
    title={entry.data.title ?? ""}
    slug={slug}
    headings={headings}
    tocDepth={tocDepth}
    section={section}
  />
</Layout>
